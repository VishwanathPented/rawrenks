# =============================================================================
# RAWRENKS BACKEND — ENVIRONMENT VARIABLE TEMPLATE
# =============================================================================
# Copy this file to `.env` in the same folder and fill in your real values.
# Never commit the filled-in .env — it is already in .gitignore.
# =============================================================================


# -------- RUNTIME ------------------------------------------------------------
NODE_ENV=development
PORT=4000


# -------- DATABASE -----------------------------------------------------------
# MongoDB Atlas SRV URI. Do NOT include a trailing /db-name.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net


# -------- AUTH / JWT ---------------------------------------------------------
JWT_SECRET=replace_with_long_random_hex
SELLER_EMAIL=admin@rawrenks.com
SELLER_PASSWORD=replace_with_strong_password


# -------- IMAGE UPLOAD (Cloudinary) ------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


# -------- PAYMENTS (Razorpay) ------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret


# -------- EMAIL / OTP (SMTP) -------------------------------------------------
# Brevo or Gmail app password — see README for setup notes.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_login
SMTP_PASS=your_smtp_password
SMTP_EMAIL=no-reply@rawrenks.com


# -------- FRONTEND ORIGIN(S) -------------------------------------------------
CLIENT_ORIGINS=http://localhost:5173,http://localhost:4000,http://127.0.0.1:5500
